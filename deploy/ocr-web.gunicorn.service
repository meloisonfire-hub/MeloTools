[Unit]
Description=OCR Web App
After=network.target

[Service]
Type=simple
User=ocrweb
Group=ocrweb
WorkingDirectory=/srv/ocr-web
Environment=PYTHONUNBUFFERED=1
Environment=TMPDIR=/srv/ocr-web/tmp
Environment=TEMP=/srv/ocr-web/tmp
Environment=TMP=/srv/ocr-web/tmp
ExecStart=/srv/ocr-web/venv/bin/gunicorn --workers 2 --threads 4 --bind 0.0.0.0:8080 --timeout 600 app:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
